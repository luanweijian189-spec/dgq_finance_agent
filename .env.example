APP_ENV=prod
DEBUG=false

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dgq_finance_agent

SCHEDULER_ENABLED=true
SCHEDULER_CRON=30 15 * * 1-5
SCHEDULER_NEWS_SCAN_ENABLED=true
SCHEDULER_NEWS_SCAN_CRON=*/20 9-15 * * 1-5
SCHEDULER_INTRADAY_REFRESH_ENABLED=false
SCHEDULER_INTRADAY_REFRESH_CRON=*/5 9-15 * * 1-5
SCHEDULER_INTRADAY_REFRESH_LIMIT=12
SCHEDULER_INTRADAY_REFRESH_MIN_CHANGE_PERCENT=0.8
SCHEDULER_INTRADAY_REFRESH_FORCE_NOTIFY=false

# 推荐：baostock（真实行情）
MARKET_DATA_PROVIDER=baostock

# 推荐：freebest（pytdx 主源 + akshare 回退）
# 可选：freebest / pytdx / akshare
INTRADAY_DATA_PROVIDER=freebest
INTRADAY_REQUEST_INTERVAL_SECONDS=1.2
INTRADAY_MAX_RETRIES=2
INTRADAY_PYTDX_BAR_COUNT=800
INTRADAY_PYTDX_TICK_LIMIT=2000
# 可选：手工指定稳定的通达信主机，多个逗号分隔；不填则使用 pytdx 内置主机列表
INTRADAY_PYTDX_HOSTS=

# 可选：tushare / webhook / sites（交付建议使用 sites 或 tushare）
NEWS_DATA_PROVIDER=sites

# 当 NEWS_DATA_PROVIDER=tushare 时必填
TUSHARE_TOKEN=

# 当 NEWS_DATA_PROVIDER=webhook 时使用
NEWS_WEBHOOK_URL=

# 当 NEWS_DATA_PROVIDER=sites 时使用（多个站点逗号分隔）
NEWS_SITE_WHITELIST=https://www.eastmoney.com,https://finance.sina.com.cn,https://www.stcn.com,https://www.cnstock.com
NEWS_SITE_TIMEOUT=5
NEWS_DISCOVERY_MIN_SCORE=2.5
NEWS_AUTO_PROMOTE_MIN_SCORE=3.8

# 可选：配置后会把告警和日报推送到该 webhook
ALERT_WEBHOOK_URL=

# 推荐：钉钉企业机器人 + Stream 模式
# Stream 模式不需要公网回调、域名和证书，适合做群里 @机器人 + 主动推送
DINGTALK_BOT_ENABLED=false
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ROBOT_CODE=
# 主动发群消息需要 openConversationId，可先通过 Stream relay 日志拿到
DINGTALK_OPEN_CONVERSATION_ID=
DINGTALK_API_BASE_URL=https://api.dingtalk.com
DINGTALK_OAUTH_URL=https://api.dingtalk.com/v1.0/oauth2/accessToken
DINGTALK_TIMEOUT_SECONDS=10

# 钉钉 Stream relay（推荐）
DINGTALK_STREAM_CLIENT_ID=
DINGTALK_STREAM_CLIENT_SECRET=
DINGTALK_STREAM_BACKEND_WEBHOOK_URL=http://127.0.0.1:8000/api/connectors/dingtalk/webhook
DINGTALK_STREAM_SHARED_TOKEN=
DINGTALK_STREAM_ALLOW_GROUP_CHAT=true
DINGTALK_STREAM_ALLOW_SINGLE_CHAT=true
DINGTALK_STREAM_ALLOWED_CONVERSATION_IDS=
DINGTALK_STREAM_PROCESS_ONLY_AT_MESSAGES=true
DINGTALK_STREAM_REPLY_ENABLED=true

# Agent 矩阵：用于把钉钉/OpenClaw 消息转成代码任务，并可切换到外部 API
AGENT_MATRIX_ENABLED=true
AGENT_MATRIX_PROVIDER=local
AGENT_MATRIX_STORE_PATH=data/runtime/agent_matrix_tasks.jsonl
AGENT_MATRIX_WORKSPACE=.
AGENT_MATRIX_LOOP_SCRIPT=scripts/copilot_hybrid_loop.sh
AGENT_MATRIX_BRIEF_DIR=data/runtime/agent_matrix
AGENT_MATRIX_DEFAULT_BRANCH=main
AGENT_MATRIX_HTTP_BASE_URL=
AGENT_MATRIX_HTTP_API_KEY=
AGENT_MATRIX_TIMEOUT_SECONDS=30
AGENT_MATRIX_AUTO_CHECK=false

# Repo Ops：面向“消息 -> agent矩阵 -> 自动管理代码库”的下一跳编排接口
REPO_OPS_ENABLED=true
REPO_OPS_PROVIDER=local
REPO_OPS_STORE_PATH=data/runtime/repo_ops_tasks.jsonl
REPO_OPS_WORKSPACE=.
REPO_OPS_DEFAULT_BRANCH=main
REPO_OPS_HTTP_BASE_URL=
REPO_OPS_HTTP_API_KEY=
REPO_OPS_TIMEOUT_SECONDS=30
REPO_OPS_REQUIRE_HUMAN_APPROVAL=true
REPO_OPS_ALLOW_GIT_WRITE=false
REPO_OPS_ALLOW_GIT_PUSH=false
REPO_OPS_ALLOW_SHELL=false
REPO_OPS_MAX_FILES=20
REPO_OPS_ALLOWED_GLOBS=app/**,scripts/**,tests/**,README.md,design_docs/**
REPO_OPS_BLOCKED_GLOBS=.env,.env.*,data/**,runtime/**,.venv/**

# 官方推荐：通过 OpenClaw 已配置好的 QQ 通道发送通知
# 示例发送命令：openclaw --dev agent --channel qq --deliver -m '测试消息'
OPENCLAW_NOTIFIER_ENABLED=false
OPENCLAW_COMMAND=openclaw
OPENCLAW_PROFILE=dev
OPENCLAW_CHANNEL=qq
OPENCLAW_RECIPIENT=
OPENCLAW_TIMEOUT_SECONDS=30

# QQ 通知 MVP：走 NapCat / go-cqhttp 风格 HTTP API
# 例如：http://127.0.0.1:3000
QQ_BOT_ENABLED=false
QQ_BOT_BASE_URL=
QQ_BOT_TARGET_TYPE=group
QQ_BOT_TARGET_ID=
QQ_BOT_ACCESS_TOKEN=

# QQ 开放平台官方 Bot（推荐用于官方双向通信）
# 回调地址建议配置为：https://你的域名/api/connectors/qq/official/webhook
QQ_OFFICIAL_BOT_ENABLED=false
QQ_OFFICIAL_BOT_APP_ID=
QQ_OFFICIAL_BOT_APP_SECRET=
QQ_OFFICIAL_BOT_API_BASE_URL=https://api.sgroup.qq.com
QQ_OFFICIAL_BOT_TOKEN_URL=https://bots.qq.com/app/getAppAccessToken
QQ_OFFICIAL_BOT_TARGET_TYPE=group
QQ_OFFICIAL_BOT_TARGET_ID=
QQ_OFFICIAL_BOT_TIMEOUT_SECONDS=10

# OpenClaw / QQ / 其他连接器回调后端时的共享令牌；会校验 X-Connector-Token / Bearer / token 字段
# 注意：QQ 官方回调走签名校验，不依赖这个令牌。
CONNECTOR_SHARED_TOKEN=

# 手机/公网访问前端时建议开启基础认证
WEB_BASIC_AUTH_ENABLED=false
WEB_BASIC_AUTH_USERNAME=finance
WEB_BASIC_AUTH_PASSWORD=
QQ_ONEBOT_RELAY_BACKEND_WEBHOOK_URL=http://127.0.0.1:8000/api/connectors/qq/webhook
QQ_ONEBOT_RELAY_SHARED_TOKEN=
QQ_ONEBOT_RELAY_ONEBOT_API_BASE_URL=http://127.0.0.1:5700
QQ_ONEBOT_RELAY_ONEBOT_ACCESS_TOKEN=
QQ_ONEBOT_RELAY_ALLOWED_GROUP_IDS=
QQ_ONEBOT_RELAY_ALLOW_PRIVATE=false
QQ_ONEBOT_RELAY_PORT=5701

# go-cqhttp / OneBot 本机运行配置（推荐放在 runtime/go-cqhttp）
GO_CQHTTP_HOME=runtime/go-cqhttp
GO_CQHTTP_QQ=1612085779
GO_CQHTTP_HTTP_API_ADDRESS=127.0.0.1:5700
GO_CQHTTP_ACCESS_TOKEN=
GO_CQHTTP_POST_URL=http://127.0.0.1:5701/webhook
GO_CQHTTP_DOWNLOAD_URL=
GO_CQHTTP_EXTRA_ARGS=
GO_CQHTTP_SIGN_SERVER_URL=
GO_CQHTTP_SIGN_SERVER_KEY=
GO_CQHTTP_SIGN_SERVER_AUTHORIZATION=-
GO_CQHTTP_SIGN_AUTO_REGISTER=true
GO_CQHTTP_SIGN_AUTO_REFRESH_TOKEN=true
GO_CQHTTP_SIGN_REFRESH_INTERVAL=40
GO_CQHTTP_SIGN_IS_BELOW_110=false

# 非荐股资讯RAG存储位置
RAG_STORE_PATH=data/research_notes.jsonl

# 每支股票单独维护的知识文件目录（用于长期追踪与RAG）
STOCK_KNOWLEDGE_DIR=data/stocks

# 每日股票池追踪文件输出目录（按日期命名）
DAILY_REPORT_DIR=reports/daily

# 记忆系统后端（当前支持 jsonl，后续可扩展向量库）
MEMORY_BACKEND=jsonl

# 每次分析检索的记忆条数（RAG上下文窗口）
MEMORY_RETRIEVAL_LIMIT=8

# 智能分析模型（默认接本地免费 Ollama OpenAI 兼容接口）
# 先执行：ollama serve
# 再执行：ollama pull qwen2.5:3b
ANALYSIS_MODEL=qwen2.5:3b
LLM_API_BASE=http://127.0.0.1:11434/v1
LLM_API_KEY=
LLM_API_CHAT_PATH=/chat/completions
LLM_API_TIMEOUT_SECONDS=15
