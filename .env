APP_ENV=dev
DEBUG=true

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/dgq_finance_agent

SCHEDULER_ENABLED=true
SCHEDULER_CRON=30 15 * * 1-5

# 推荐：baostock（真实行情）
MARKET_DATA_PROVIDER=baostock

# 可选：mock / tushare / webhook / sites
NEWS_DATA_PROVIDER=tushare

# 当 NEWS_DATA_PROVIDER=tushare 时必填
TUSHARE_TOKEN=

# 当 NEWS_DATA_PROVIDER=webhook 时使用
NEWS_WEBHOOK_URL=

# 当 NEWS_DATA_PROVIDER=sites 时使用（多个站点逗号分隔）
NEWS_SITE_WHITELIST=https://www.eastmoney.com,https://finance.sina.com.cn,https://www.stcn.com,https://www.cnstock.com
NEWS_SITE_TIMEOUT=5

# 每支股票单独维护的知识文件目录（用于长期追踪与RAG）
STOCK_KNOWLEDGE_DIR=data/stocks

# 可选：配置后会把告警和日报推送到该 webhook
ALERT_WEBHOOK_URL=
