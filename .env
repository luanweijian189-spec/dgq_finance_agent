APP_ENV=prod
DEBUG=false

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/dgq_finance_agent

SCHEDULER_ENABLED=true
SCHEDULER_CRON=30 15 * * 1-5
SCHEDULER_NEWS_SCAN_ENABLED=true
SCHEDULER_NEWS_SCAN_CRON=*/20 9-15 * * 1-5
SCHEDULER_INTRADAY_REFRESH_ENABLED=true
SCHEDULER_INTRADAY_REFRESH_CRON=*/5 9-15 * * 1-5
SCHEDULER_INTRADAY_REFRESH_LIMIT=12
SCHEDULER_INTRADAY_REFRESH_MIN_CHANGE_PERCENT=0.8
SCHEDULER_INTRADAY_REFRESH_FORCE_NOTIFY=false

# 推荐：baostock（真实行情）
MARKET_DATA_PROVIDER=baostock

# 推荐：freebest（pytdx 主源 + akshare 回退）
# 可选：freebest / pytdx / akshare
INTRADAY_DATA_PROVIDER=freebest
INTRADAY_REQUEST_INTERVAL_SECONDS=1.2
INTRADAY_MAX_RETRIES=2
INTRADAY_PYTDX_BAR_COUNT=800
INTRADAY_PYTDX_TICK_LIMIT=2000
# 可选：手工指定稳定的通达信主机，多个逗号分隔；不填则使用 pytdx 内置主机列表
INTRADAY_PYTDX_HOSTS=

# 可选：tushare / webhook / sites（交付建议使用 sites 或 tushare）
NEWS_DATA_PROVIDER=sites

# 当 NEWS_DATA_PROVIDER=tushare 时必填
TUSHARE_TOKEN=

# 当 NEWS_DATA_PROVIDER=webhook 时使用
NEWS_WEBHOOK_URL=

# 当 NEWS_DATA_PROVIDER=sites 时使用（多个站点逗号分隔）
NEWS_SITE_WHITELIST=https://www.eastmoney.com,https://finance.sina.com.cn,https://www.stcn.com,https://www.cnstock.com
NEWS_SITE_TIMEOUT=5
NEWS_DISCOVERY_MIN_SCORE=2.5
NEWS_AUTO_PROMOTE_MIN_SCORE=3.8

# 可选：配置后会把告警和日报推送到该 webhook
ALERT_WEBHOOK_URL=

# 官方推荐：通过 OpenClaw 已配置好的 QQ 通道发送通知
# 示例发送命令：openclaw --dev agent --channel qq --deliver -m '测试消息'
OPENCLAW_NOTIFIER_ENABLED=true
OPENCLAW_COMMAND=openclaw
OPENCLAW_PROFILE=dev
OPENCLAW_CHANNEL=qq
OPENCLAW_RECIPIENT=
OPENCLAW_TIMEOUT_SECONDS=30

# QQ 通知 MVP：走 NapCat / go-cqhttp 风格 HTTP API
# 例如：http://127.0.0.1:3000
QQ_BOT_ENABLED=false
QQ_BOT_BASE_URL=
QQ_BOT_TARGET_TYPE=group
QQ_BOT_TARGET_ID=
QQ_BOT_ACCESS_TOKEN=
QQ_OFFICIAL_BOT_ENABLED=true
QQ_OFFICIAL_BOT_APP_ID=1903211003
QQ_OFFICIAL_BOT_APP_SECRET=kR8qZI2mXI4qdQE321112357AEINSYel
QQ_OFFICIAL_BOT_API_BASE_URL=https://api.sgroup.qq.com
QQ_OFFICIAL_BOT_TOKEN_URL=https://bots.qq.com/app/getAppAccessToken
QQ_OFFICIAL_BOT_TARGET_TYPE=group
QQ_OFFICIAL_BOT_TARGET_ID=
QQ_OFFICIAL_BOT_TIMEOUT_SECONDS=10

# 非荐股资讯RAG存储位置
RAG_STORE_PATH=data/research_notes.jsonl

# 每支股票单独维护的知识文件目录（用于长期追踪与RAG）
STOCK_KNOWLEDGE_DIR=data/stocks

# 每日股票池追踪文件输出目录（按日期命名）
DAILY_REPORT_DIR=reports/daily

# 记忆系统后端（当前支持 jsonl，后续可扩展向量库）
MEMORY_BACKEND=jsonl

# 每次分析检索的记忆条数（RAG上下文窗口）
MEMORY_RETRIEVAL_LIMIT=8

# 智能分析模型（默认接本地免费 Ollama OpenAI 兼容接口）
# 先执行：ollama serve
# 再执行：ollama pull qwen2.5:3b
ANALYSIS_MODEL=qwen2.5:3b
LLM_API_BASE=http://127.0.0.1:11434/v1
LLM_API_KEY=
LLM_API_CHAT_PATH=/chat/completions
LLM_API_TIMEOUT_SECONDS=15

CONNECTOR_SHARED_TOKEN=lJtzsxKNpVIyYNdSq08qd03GazQWaffoHMIAi7E1-sE

WEB_BASIC_AUTH_ENABLED=true

WEB_BASIC_AUTH_USERNAME=finance

WEB_BASIC_AUTH_PASSWORD=yiqizhuanqian

QQ_ONEBOT_RELAY_BACKEND_WEBHOOK_URL=http://127.0.0.1:8000/api/connectors/qq/webhook

QQ_ONEBOT_RELAY_SHARED_TOKEN=lJtzsxKNpVIyYNdSq08qd03GazQWaffoHMIAi7E1-sE

QQ_ONEBOT_RELAY_ONEBOT_API_BASE_URL=http://127.0.0.1:5700

QQ_ONEBOT_RELAY_ONEBOT_ACCESS_TOKEN=

QQ_ONEBOT_RELAY_ALLOWED_GROUP_IDS=

QQ_ONEBOT_RELAY_ALLOW_PRIVATE=false

QQ_ONEBOT_RELAY_PORT=5701
